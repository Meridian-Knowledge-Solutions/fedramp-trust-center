  "human_process_resources": {
    "schema": "FRR-MAS Human and Process Resources",
    "version": "1.0.0",
    "last_updated": "2026-03-07",
    "description": "Supplements the MAS machine resource inventory (KSI-AFR-01) with human and process resources within the FedRAMP authorization boundary. Per FRR-MAS requirements, the Minimum Assessment Scope must account for people, processes, and technology \u2014 not just infrastructure.",
    "human_resources": {
      "security_roles": [
        {
          "role": "Information System Security Officer (ISSO)",
          "responsibility": "Maintains the security posture of the Meridian LMS authorization boundary. Responsible for continuous monitoring, POA&M management, and FedRAMP deliverables.",
          "clearance_required": false,
          "us_based": true,
          "assessment_scope": "Annual assessment interviews, control implementation verification, ConMon deliverable review"
        },
        {
          "role": "System Administrator",
          "responsibility": "Manages AWS infrastructure within the authorization boundary including EC2, RDS, S3, VPC, and IAM configurations.",
          "clearance_required": false,
          "us_based": true,
          "assessment_scope": "Privileged access review, change management verification, configuration baseline compliance"
        },
        {
          "role": "Security Operations / Incident Response",
          "responsibility": "Monitors security events, responds to incidents per FRR-ICP procedures, and conducts IR/DR training and tabletop exercises.",
          "clearance_required": false,
          "us_based": true,
          "assessment_scope": "Incident response capability testing (KSI-RPL-04), training effectiveness (KSI-CED-04), alert response times"
        },
        {
          "role": "Development Team Lead",
          "responsibility": "Manages SDLC security practices, code review, and deployment pipeline security for the Meridian LMS application.",
          "clearance_required": false,
          "us_based": true,
          "assessment_scope": "SDLC policy compliance, secure coding practices, change management process adherence"
        },
        {
          "role": "Authorizing Official Designee",
          "responsibility": "Meridian executive responsible for accepting residual risk and authorizing operation of the system.",
          "clearance_required": false,
          "us_based": true,
          "assessment_scope": "Risk acceptance decisions, POA&M oversight, authorization boundary changes"
        }
      ],
      "staffing_model": {
        "total_boundary_personnel": 8,
        "all_us_based": true,
        "all_us_persons": true,
        "note": "Meridian Knowledge Solutions is a U.S.-based company with all development and support handled by U.S.-based personnel."
      }
    },
    "process_resources": [
      {
        "process": "Continuous Monitoring (ConMon)",
        "description": "Automated daily KSI validation via CLI pipeline, OAR generation, and QAR reporting. Human review of findings and remediation tracking.",
        "ksi_coverage": [
          "KSI-AFR-02",
          "KSI-MLA-02",
          "KSI-MLA-07"
        ],
        "frequency": "Daily (automated), Monthly (OAR), Quarterly (QAR)",
        "assessment_scope": "ConMon deliverable accuracy, timeliness, and coverage"
      },
      {
        "process": "Vulnerability Management",
        "description": "Multi-source vulnerability scanning (Inspector, Security Hub, Aikido, OSV, Bandit, External Scanner) with Jira SEC tracking and VDR reporting.",
        "ksi_coverage": [
          "KSI-TPR-04",
          "KSI-AFR-04"
        ],
        "frequency": "Continuous (scanning), 3-day (VDR reports)",
        "assessment_scope": "Scan coverage, remediation timeliness, VDR accuracy"
      },
      {
        "process": "Incident Response",
        "description": "Automated incident communication workflow (FRR-ICP) with Jira SEC integration, Lambda notification dispatch, and SLA tracking.",
        "ksi_coverage": [
          "KSI-AFR-10",
          "KSI-RPL-04",
          "KSI-CED-04"
        ],
        "frequency": "Event-driven, tabletop exercises quarterly",
        "assessment_scope": "SLA compliance, notification accuracy, post-incident review"
      },
      {
        "process": "Change Management",
        "description": "GitOps-based change management with SCN classification (routine/adaptive/transformative), approval workflows, and security impact assessment.",
        "ksi_coverage": [
          "KSI-CMT-01",
          "KSI-CMT-02"
        ],
        "frequency": "Per change event, SCN reporting as needed",
        "assessment_scope": "Change classification accuracy, notification timeliness, security impact assessment quality"
      },
      {
        "process": "Access Control and Identity Management",
        "description": "Okta-based federal identity with PIV/CAC support, SAML 2.0 SSO, role-based access control within Meridian LMS and AWS IAM.",
        "ksi_coverage": [
          "KSI-IAM-01",
          "KSI-IAM-02",
          "KSI-CNA-01"
        ],
        "frequency": "Continuous (authentication), Quarterly (access review)",
        "assessment_scope": "Privileged access inventory, authentication strength, access review completeness"
      },
      {
        "process": "Security Governance",
        "description": "Policy and procedure management via CodeCommit security-governance repository. Version-controlled policies with attestation tracking.",
        "ksi_coverage": [
          "KSI-CED-01",
          "KSI-CED-02",
          "KSI-CED-03"
        ],
        "frequency": "Annual review, event-driven updates",
        "assessment_scope": "Policy currency, attestation completeness, governance repository integrity"
      }
    ],
